aws_region         = "ap-northeast-2"
network_state_path = "../network/terraform.tfstate"

name_prefix = "ktcloud2nd-dev"

db_name     = "vehicle_db"
db_username = "dbadmin"
db_password = "change-me"

instance_class          = "db.t3.micro"
allocated_storage       = 20
storage_type            = "gp3"
backup_retention_period = 1

tags = {
  Environment = "dev"
  Owner       = "infra3"
}
