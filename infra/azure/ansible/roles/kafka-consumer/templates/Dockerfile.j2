FROM confluentinc/cp-kafka-connect:7.5.0

USER root
# 압축 해제를 위한 unzip 설치
RUN microdnf update && microdnf install -y unzip && microdnf clean all

# zip 파일들을 컨테이너 임시 폴더로 복사
# confluentinc-kafka-connect-azure-blob-storage-2.1.2
# confluentinc-kafka-connect-s3-10.5.0
COPY azure-part1.zip azure-part2.zip s3.zip /tmp/

# 플러그인 폴더 생성 및 압축 해제
# azure-part1과 part2를 똑같은 경로에 풀어 파일 합치기
RUN mkdir -p /usr/share/confluent-hub-components/azure-blob && \
    mkdir -p /usr/share/confluent-hub-components/s3 && \
    unzip /tmp/azure-part1.zip -d /usr/share/confluent-hub-components/azure-blob && \
    unzip /tmp/azure-part2.zip -d /usr/share/confluent-hub-components/azure-blob && \
    unzip /tmp/s3.zip -d /usr/share/confluent-hub-components/s3 && \
    rm /tmp/*.zip

# 권한 정리
RUN chown -R appuser:appuser /usr/share/confluent-hub-components

USER appuser

# Kafka Connect가 플러그인을 인식하도록 경로 설정
ENV CONNECT_PLUGIN_PATH="/usr/share/java,/usr/share/confluent-hub-components"

CMD ["/etc/confluent/docker/run"]